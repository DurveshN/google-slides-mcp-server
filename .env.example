# Google Slides MCP Server - Environment Variables Template
# Copy this file to .env and fill in your values

# Path to your Google OAuth credentials file
# Download from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CREDENTIALS=./credentials.json

# Enable debug logging (optional)
# Set to "true" to enable detailed logging for troubleshooting
# Logs are written to .sisyphus/evidence/tool-test-report.md
CALLMISSED=false

# Note: Never commit the actual .env file or credentials.json to version control!
# These files contain sensitive authentication information.
